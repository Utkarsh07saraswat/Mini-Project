# Application Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/multi_tenant

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# Encryption Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SECRET=your-encryption-secret-key-change-this-in-production

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting Configuration
# Tenant tier configuration (optional - defaults to 'default' tier)
# TENANT_TENANT-A_TIER=premium
# TENANT_TENANT-B_TIER=enterprise

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key
BACKUP_RETENTION_COUNT=7
S3_BACKUP_BUCKET=

# Monitoring & Logging
LOG_LEVEL=info
ENABLE_AUDIT_LOGS=true
ENABLE_METRICS=true

# Optional: AWS Configuration for S3 backups
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
